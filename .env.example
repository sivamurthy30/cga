# Backend API Configuration
REACT_APP_API_URL=http://localhost:8000

# Hugging Face API Token (for AI Assistant)
# Get your token from: https://huggingface.co/settings/tokens
REACT_APP_HF_TOKEN=your-huggingface-token-here

# Backend Environment Variables (for backend/.env)
# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/career_guidance
# Or for SQLite (development)
# DATABASE_URL=sqlite:///data/career_guidance.db

# SMS API (Optional - for OTP)
FAST2SMS_API_KEY=your-fast2sms-api-key

# Security
SESSION_SECRET=your-session-secret-here
JWT_SECRET=your-jwt-secret-here

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# File Upload
MAX_UPLOAD_SIZE=16777216  # 16MB in bytes
UPLOAD_FOLDER=data/uploads

# ============================================
# FastAPI Backend Configuration
# ============================================

# App Configuration
APP_NAME="DEVA Career Guidance API"
APP_VERSION="2.0.0"
DEBUG=False
ENVIRONMENT=development

# FastAPI Server
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Security (CHANGE IN PRODUCTION!)
FASTAPI_SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins for FastAPI (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@deva.ai

# ML Models Path
ML_MODEL_PATH=./ml_models
