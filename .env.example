# ── DEVA Environment Variables ──────────────────────────────────────────────
# Copy this file to backend/.env and fill in your values
# Never commit the actual .env file

# App
ENVIRONMENT=production
SECRET_KEY=your-secret-key-min-32-chars-change-this

# MongoDB Atlas
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=deva_career

# Razorpay (get from dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here

# CORS — your Vercel frontend URL
CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]

# Token expiry
ACCESS_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_EXPIRE_DAYS=7
