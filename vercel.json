{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://deva-backend.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://deva-backend.onrender.com/health"
    },
    {
      "source": "/((?!api|health).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "create-react-app"
}
